# LLM provider — any Anthropic-API-compatible endpoint with a vision-capable model.
# Reached via @anthropic-ai/sdk; these project-scoped names avoid clashing
# with a host-level ANTHROPIC_BASE_URL that some desktop tools export.
LLM_BASE_URL=https://your-endpoint.example.com
LLM_API_KEY=your-api-key
LLM_MODEL=your-vision-model-id
